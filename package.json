{
  "name": "game-dev-simulator",
  "version": "0.1.0",
  "description": "游戏制作人模拟器 - 卡牌肉鸽模拟经营游戏",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check:style": "npm run lint && npm run format:check"
  },
  "dependencies": {
    "immer": "^11.1.4",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
