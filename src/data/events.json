    "triggerCondition": { "month": 1, "day": 1 },
    "priority": 100,
    "phases": [
      {
        "text": "你站在崭新的工作室门口，深吸一口气。这里将是梦开始的地方。",
        "choices": [
          {
            "text": "\"我们一定能做出伟大的游戏！\"",
            "effects": [{ "type": "morale", "value": 10 }]
          },
          { "text": "\"先活下来再说吧...\"", "effects": [{ "type": "funds", "value": 2000 }] }
        ]
      }
    ],
    "effects": []
  },
  {
    "id": "event_first_bug",
    "name": "第一个严重Bug",
