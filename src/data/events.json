    "type": "TIMELINE",
    "triggerCondition": { "month": 2, "day": 1 },
    "priority": 100,
    "phases": [
      {
        "text": "噼里啪啦网上炸了锅：国家新闻出版署暂停游戏版号审批。整个行业一片哀嚎。",
        "speaker": "系统"
      },
      {
        "text": "没有版号，游戏就无法上线盈利。工作室的前途变得不明朗...",
        "choices": [
          {
            "text": "趁这段时间专心打磨品质",
            "effects": [
              { "type": "morale", "value": -5 },
              {
                "type": "buff",
                "target": "buff_event_morale_high",
                "value": 1,
                "duration": 2,
                "durationUnit": "week"
              }
            ]
          },
          {
            "text": "考虑出海发行",
            "effects": [
              { "type": "funds", "value": -3000 },
              { "type": "reputation", "value": 5 }
            ]
          },
          {
            "text": "缩减团队规模熬过去",
            "effects": [
              { "type": "funds", "value": 5000 },
              { "type": "morale", "value": -20 }
            ]
          }
        ]
      }
    ],
    "effects": []
  },
  {
